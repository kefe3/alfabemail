#!/usr/bin/env php
<?php

use Illuminate\Foundation\Application;
use Symfony\Component\Console\Input\ArgvInput;

define('LARAVEL_START', microtime(true));

// .env dosyasından APP_ENV oku (framework henüz yüklenmedi)
$envFile = __DIR__ . '/.env';
$appEnv = getenv('APP_ENV') ?: ($_SERVER['APP_ENV'] ?? $_ENV['APP_ENV'] ?? false);

if (!$appEnv && file_exists($envFile)) {
    foreach (file($envFile) as $line) {
        $line = trim($line);
        if ($line === '' || str_starts_with($line, '#')) continue;
        if (str_starts_with($line, 'APP_ENV=')) {
            $appEnv = substr($line, 8);
            break;
        }
    }
}

if ($appEnv === 'production') {
    $forbidden = ['migrate:fresh', 'migrate:refresh', 'migrate:reset', 'migrate:rollback', 'db:wipe'];
    $command = $_SERVER['argv'][1] ?? '';
    $name = explode(' ', $command)[0];

    if (in_array($name, $forbidden, true)) {
        fwrite(STDERR, "\n  \e[31m[ERROR]\e[0m `{$name}` komutu production ortamında çalıştırılamaz!\n\n");
        exit(1);
    }
}

require __DIR__.'/vendor/autoload.php';

/** @var Application $app */
$app = require_once __DIR__.'/bootstrap/app.php';

$status = $app->handleCommand(new ArgvInput);

exit($status);
